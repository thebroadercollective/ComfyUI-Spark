+# =============================================================================
+# DGX Spark Unified Memory Helpers
+# =============================================================================
+
+def _is_unified_memory() -> bool:
+    """Check if running on a unified memory system (DGX Spark)."""
+    try:
+        import comfy.model_management as model_management
+        return getattr(model_management, "UNIFIED_MEMORY", False)
+    except ImportError:
+        return False
+
+
+def _page_cache_dropper(safetensors_files, stop_event, interval=30):
+    """Background thread: drop OS page cache for safetensors files periodically.
+
+    On unified memory, mmap'd page cache competes with CUDA allocations for the
+    same physical pool. Dropping it mid-load keeps peak memory lower.
+    """
+    try:
+        import comfy.model_management as model_management
+    except ImportError:
+        return
+    while not stop_event.wait(interval):
+        dropped = 0
+        for path in safetensors_files:
+            if model_management.drop_file_page_cache(path):
+                dropped += 1
+        if dropped:
+            logger.info("PAGE_CACHE_DROP_TICK | dropped %d shards", dropped)
+
+
+@contextmanager
+def _mid_load_page_cache_drop(model_path):
+    """Drop page cache periodically during from_pretrained() on unified memory.
+
+    Wraps a from_pretrained() call with a background thread that drops OS page
+    cache for all safetensors shards every 30 seconds, plus a final sweep after
+    loading completes. No-op on non-unified-memory systems.
+    """
+    if not _is_unified_memory():
+        yield
+        return
+
+    try:
+        import comfy.model_management as model_management
+    except ImportError:
+        yield
+        return
+
+    safetensors_files = sorted(glob.glob(os.path.join(model_path, "*.safetensors")))
+    if not safetensors_files:
+        yield
+        return
+
+    logger.info("PAGE_CACHE_DROP | starting background dropper for %d shards", len(safetensors_files))
+    stop_event = threading.Event()
+    dropper = threading.Thread(
+        target=_page_cache_dropper,
+        args=(safetensors_files, stop_event),
+        daemon=True,
+    )
+    dropper.start()
+    try:
+        yield
+    finally:
+        stop_event.set()
+        dropper.join(timeout=5)
+        # Final sweep to catch any remaining page cache
+        dropped = 0
+        for path in safetensors_files:
+            if model_management.drop_file_page_cache(path):
+                dropped += 1
+        if dropped:
+            logger.info("PAGE_CACHE_DROP | final sweep, %d shards", dropped)
+
+
